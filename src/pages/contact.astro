---
import BaseLayout from '../layouts/BaseLayout.astro';
import Faq from '../components/Faq.astro';
import { SITE, SOCIAL } from '../consts';
import { breadcrumb, faqPage } from '../schema';

const title = 'Contact Nisarth Patel: Start a Project';
const description =
  'Get in touch with Nisarth Patel for SEO, AI automation, or web development. Based in Ahmedabad, available for projects across India and worldwide.';

const faqs = [
  {
    q: 'How soon will you reply?',
    a: 'I usually reply within one business day. If your message is urgent, send a WhatsApp and I will get back to you faster.',
  },
  {
    q: 'What should I include in my message?',
    a: 'A short note on your business, what you want to improve, and any deadline. The more context you give, the more useful my first reply will be.',
  },
  {
    q: 'Do you work with clients outside India?',
    a: 'Yes. I work remotely with clients across India and internationally.',
  },
];
---

<BaseLayout
  title={title}
  description={description}
  path="/contact.html"
  jsonLd={[
    breadcrumb([{ name: 'Home', path: '/' }, { name: 'Contact', path: '/contact.html' }]),
    faqPage(faqs),
  ]}
>
  <section class="section">
    <div class="container contact-grid">
      <div class="contact-intro">
        <p class="eyebrow">Contact</p>
        <h1>Let us talk about your project</h1>
        <p class="lead">
          Tell me what you are trying to grow. I will reply with a clear next step,
          usually within one business day.
        </p>
        <ul class="contact-methods">
          <li>
            <span class="label">Email</span>
            <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
          </li>
          <li>
            <span class="label">WhatsApp</span>
            <a href={SITE.whatsappLink} rel="noopener noreferrer" target="_blank">{SITE.whatsappDisplay}</a>
          </li>
          <li>
            <span class="label">Location</span>
            <span>{SITE.location}</span>
          </li>
          <li class="contact-social">
            <a href={SOCIAL.linkedin} rel="noopener noreferrer" target="_blank">LinkedIn</a>
            <a href={SOCIAL.twitter} rel="noopener noreferrer" target="_blank">X</a>
            <a href={SOCIAL.github} rel="noopener noreferrer" target="_blank">GitHub</a>
          </li>
        </ul>
      </div>

      <form
        class="card contact-form"
        action={`https://formsubmit.co/${SITE.email}`}
        method="POST"
        aria-label="Contact form"
      >
        <!-- formsubmit.co settings -->
        <input type="hidden" name="_subject" value="New enquiry from nisarth.github.io" />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_captcha" value="false" />
        <!-- Honeypot: real people leave this empty -->
        <input type="text" name="_honey" class="visually-hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

        <div class="field">
          <label for="name">Name</label>
          <input id="name" name="name" type="text" required autocomplete="name" />
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="field">
          <label for="service">What do you need help with?</label>
          <select id="service" name="service">
            <option value="SEO">SEO</option>
            <option value="AEO and GEO">AEO and GEO</option>
            <option value="AI automation">AI automation</option>
            <option value="Web development">Web development</option>
            <option value="Marketing">Marketing</option>
            <option value="Something else">Something else</option>
          </select>
        </div>
        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Send message</button>
      </form>
    </div>
  </section>

  <Faq items={faqs} />
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  .contact-intro h1 {
    margin: 0.7rem 0 1rem;
  }
  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    margin-top: 2rem;
  }
  .contact-methods .label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.2rem;
  }
  .contact-methods a:hover {
    color: var(--accent);
  }
  .contact-social {
    flex-direction: row;
    display: flex;
    gap: 1.2rem;
    margin-top: 0.3rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .field label {
    font-size: 0.9rem;
    font-weight: 600;
  }
  .field input,
  .field select,
  .field textarea {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    padding: 0.7rem 0.85rem;
    font: inherit;
    width: 100%;
  }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    border-color: var(--accent);
    outline: none;
  }
  .contact-form button {
    align-self: flex-start;
  }

  @media (max-width: 760px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2.2rem;
    }
  }
</style>
