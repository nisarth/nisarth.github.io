---
import { NAV, SITE, SOCIAL } from '../consts';
const year = 2026;
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class="brand">
        <span class="brand-mark" aria-hidden="true">NP</span>
        <span>{SITE.name}</span>
      </a>
      <p class="muted">{SITE.role} in {SITE.location}.</p>
      <p class="muted">{SITE.tagline}</p>
    </div>

    <nav class="footer-nav" aria-label="Footer">
      <h2 class="footer-heading">Pages</h2>
      <ul>
        {NAV.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
        <li><a href="/locations.html">Locations</a></li>
      </ul>
    </nav>

    <div class="footer-contact">
      <h2 class="footer-heading">Contact</h2>
      <ul>
        <li><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
        <li>
          <a href={SITE.whatsappLink} rel="noopener noreferrer" target="_blank">
            WhatsApp {SITE.whatsappDisplay}
          </a>
        </li>
        <li class="muted">{SITE.location}</li>
      </ul>
      <ul class="footer-social">
        <li><a href={SOCIAL.linkedin} rel="noopener noreferrer" target="_blank">LinkedIn</a></li>
        <li><a href={SOCIAL.twitter} rel="noopener noreferrer" target="_blank">X</a></li>
        <li><a href={SOCIAL.github} rel="noopener noreferrer" target="_blank">GitHub</a></li>
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <p class="muted">© {year} {SITE.name}. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    background: var(--bg-elev);
    padding-block: clamp(2.5rem, 6vw, 4rem) 1.5rem;
    margin-top: var(--section-y);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.2fr;
    gap: 2.5rem;
  }
  .footer-brand .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-weight: 700;
    margin-bottom: 0.9rem;
  }
  .footer-brand .brand-mark {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: var(--accent);
    color: var(--accent-ink);
    font-size: 0.85rem;
  }
  .footer-brand p {
    margin-bottom: 0.4rem;
    max-width: 36ch;
  }
  .footer-heading {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.9rem;
  }
  .footer-nav ul,
  .footer-contact ul {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .footer-contact a:hover,
  .footer-nav a:hover {
    color: var(--accent);
  }
  .footer-social {
    flex-direction: row !important;
    gap: 1.1rem !important;
    margin-top: 1.1rem;
  }
  .footer-bottom {
    margin-top: 2.5rem;
    padding-top: 1.3rem;
    border-top: 1px solid var(--border);
  }
  @media (max-width: 720px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
